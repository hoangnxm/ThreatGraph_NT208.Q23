# =========================================================================
# NEXUSTIP - THREAT INTELLIGENCE PLATFORM
# Cấu hình môi trường Phát triển (Development)
# =========================================================================

# 1. CẤU HÌNH API BACKEND (C# .NET)
# Cổng mặc định của C# thường là 7193 (HTTPS) hoặc 5113 (HTTP)
VITE_API_URL=https://localhost:7193
VITE_API_TIMEOUT=5000

# 2. THÔNG TIN HỆ THỐNG
VITE_APP_NAME="NexusTIP - Threat Intelligence Platform"
VITE_APP_VERSION="1.0.0-alpha"
VITE_APP_DESCRIPTION="Hệ thống tra cứu và phân tích dấu vết tấn công mạng"

# 3. CẤU HÌNH ĐỒ THỊ (Dành cho phần việc của Hưng)
VITE_GRAPH_MAX_NODES=500
VITE_GRAPH_REFRESH_RATE=3000

# 4. CHẾ ĐỘ DEBUG
VITE_ENABLE_LOGS=true

# =========================================================================
# LƯU Ý: Không nên push file này lên GitHub nếu chứa thông tin nhạy cảm.
# Hãy dùng file .env.example để chia sẻ cấu hình mẫu cho nhóm.
